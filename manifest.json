{
  "id": "guildora-app-template",
  "name": "Template",
  "version": "1.0.0",
  "author": "your-github-username",
  "description": "The official Guildora app template — demonstrates all integration patterns: Hub pages, API routes, bot hooks, config fields, and i18n.",
  "repositoryUrl": "https://github.com/your-github-username/guildora-app-template",
  "license": "MIT",
  "compatibility": { "core": { "minVersion": "0.1.0" } },
  "navigation": {
    "rail": [
      { "id": "guildora-app-template", "icon": "puzzle-piece", "label": "Template",
        "to": "/apps/guildora-app-template", "order": 50, "requiredRoles": ["user"] }
    ],
    "panelGroups": [{
      "railItemId": "guildora-app-template",
      "items": [
        { "id": "template-app",   "label": "App",        "to": "/apps/guildora-app-template",       "requiredRoles": ["moderator"] },
        { "id": "template-mod",   "label": "Moderation", "to": "/apps/guildora-app-template/mod",   "requiredRoles": ["moderator"] },
        { "id": "template-admin", "label": "Admin",       "to": "/apps/guildora-app-template/admin", "requiredRoles": ["admin"] }
      ]
    }]
  },
  "permissions": [
    { "id": "read:member",    "label": "Read members",     "description": "Read member profiles and roles", "required": false },
    { "id": "write:messages", "label": "Send messages",    "description": "Send messages to channels",      "required": false }
  ],
  "pages": [
    { "id": "template-app",   "path": "/apps/guildora-app-template",       "title": "Template",   "requiredRoles": ["user"],      "component": "src/pages/index.vue" },
    { "id": "template-mod",   "path": "/apps/guildora-app-template/mod",   "title": "Moderation", "requiredRoles": ["moderator"], "component": "src/pages/mod.vue" },
    { "id": "template-admin", "path": "/apps/guildora-app-template/admin", "title": "Admin",      "requiredRoles": ["admin"],     "component": "src/pages/admin.vue" }
  ],
  "apiRoutes": [
    { "method": "GET",  "path": "/api/apps/guildora-app-template/overview",  "handler": "src/api/overview.get.ts",  "requiredRoles": ["user"] },
    { "method": "POST", "path": "/api/apps/guildora-app-template/announce",  "handler": "src/api/announce.post.ts", "requiredRoles": ["moderator"] },
    { "method": "GET",  "path": "/api/apps/guildora-app-template/config",    "handler": "src/api/config.get.ts",    "requiredRoles": ["admin"] },
    { "method": "GET",  "path": "/api/apps/guildora-app-template/settings",  "handler": "src/api/settings.get.ts",  "requiredRoles": ["admin"] }
  ],
  "botHooks": ["onVoiceActivity", "onRoleChange", "onMemberJoin", "onInteraction"],
  "configFields": [
    {
      "key": "welcomeEnabled",
      "type": "boolean",
      "label": "Enable welcome messages",
      "description": "Send a welcome message when a new member joins the server.",
      "defaultValue": true
    },
    {
      "key": "welcomeMessage",
      "type": "string",
      "label": "Welcome message",
      "description": "Message sent on member join. Use {username} as a placeholder.",
      "defaultValue": "Welcome to the server, {username}!"
    },
    {
      "key": "announcementChannelId",
      "type": "string",
      "label": "Announcement channel ID",
      "description": "Discord channel ID where moderator announcements are posted."
    }
  ],
  "requiredEnv": [],
  "installNotes": "Set welcomeMessage and announcementChannelId in App Settings to get started."
}
